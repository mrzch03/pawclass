# === 必须 ===
DATABASE_URL=postgresql://clawbox:clawbox@localhost:5432/pawclass
MISTAKES_JWT_SECRET=your-jwt-secret-here

# === 知识库 ===
KNOWLEDGE_BASE_PATH=/data/knowledge-base

# === 服务 ===
PAWCLASS_PORT=9801
PAWCLASS_BASE_URL=https://class.teachclaw.app

# === AI (课件生成 + 教学大纲) ===
PAWCLASS_AI_API_KEY=
PAWCLASS_AI_BASE_URL=
PAWCLASS_AI_MODEL=gpt-4o

# === TTS 语音 ===
STAGE_TTS_BASE_URL=
STAGE_TTS_MODEL=
STAGE_TTS_VOICE=
STAGE_TTS_DIR=./tts-cache

# === ClawBox 集成 (可选) ===
CLAWBOX_BACKEND_URL=
APP_SECRET=pawclass-secret
AGENT_IM_USER_ID=
TARGET_USER_ID=
TARGET_GROUP_ID=

# === CLI (Agent 调用时使用) ===
PAWCLASS_TOKEN=

# === Clerk 认证 (与 ClawBox 共享) ===
CLERK_ISSUER=https://innocent-raccoon-97.clerk.accounts.dev

# === OAuth2 Provider ===
OAUTH_CLIENT_ID=clawbox
OAUTH_CLIENT_SECRET=change-me-to-a-random-secret
