{
  "name": "pawclass",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "pawclass": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts serve",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "start": "bun run src/cli.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "pg": "^8.13.0",
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "nanoid": "^5.0.0",
    "partial-json": "^0.1.7",
    "jsonrepair": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
